# Nossa Jornada com Deus — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com suas credenciais Supabase

# ── Supabase (opcional — sem isso o app funciona com localStorage) ──────────
# Crie um projeto grátis em https://supabase.com
# Project Settings → API → Project URL e anon key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
